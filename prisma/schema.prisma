generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


enum Role {
  USER
  ADMIN
}

model User {
  id                String             @id @default(uuid())
  supabaseId        String             @unique
  email             String             @unique
  role              Role               @default(USER)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  profile           UserProfile?
  quizAttempts      QuizAttempt[]
  savedTerms        SavedTerm[]
  dashboardActivity DashboardActivity[]
  learningSessions  LearningSession[]
  
  // Analytics Relations
  analyticsEvents   AnalyticsEvent[]
  aiUsageLogs       AiUsageLog[]
  searchLogs        SearchLog[]
  sessionLogs       SessionLog[]
}

model UserProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName String?
  xp          Int      @default(0)
  streak      Int      @default(0)
  lastActive  DateTime @default(now())
}

model QuizAttempt {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic        String
  difficulty   String
  score        Int
  totalQs      Int
  createdAt    DateTime @default(now())
}

model SavedTerm {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  term        String
  definition  String
  createdAt   DateTime @default(now())

  @@unique([userId, term])
}

model DashboardActivity {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  actionType  String
  details     Json?
  createdAt   DateTime @default(now())
}

model LearningSession {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  durationMin Int
  createdAt   DateTime @default(now())
}

// ═════════════════════════════════════════════════════════════════════════
// ANALYTICS & TRACKING TABLES
// ═════════════════════════════════════════════════════════════════════════

model AnalyticsEvent {
  id            String   @id @default(uuid())
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  eventType     String
  eventCategory String
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([eventType, createdAt])
  @@index([userId, createdAt])
}

model AiUsageLog {
  id             String   @id @default(uuid())
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  promptType     String
  tokensInput    Int      @default(0)
  tokensOutput   Int      @default(0)
  responseTimeMs Int      @default(0)
  cacheHit       Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([promptType, createdAt])
  @@index([userId, createdAt])
}

model SearchLog {
  id             String   @id @default(uuid())
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  searchTerm     String
  searchCategory String?
  resultsCount   Int      @default(0)
  createdAt      DateTime @default(now())

  @@index([searchTerm])
  @@index([createdAt])
}

model SessionLog {
  id              String   @id @default(uuid())
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionStart    DateTime
  sessionEnd      DateTime?
  durationSeconds Int?
  device          String?
  browser         String?
  ipHash          String?
  createdAt       DateTime @default(now())

  @@index([userId, sessionStart])
}

model SystemMetric {
  id          String   @id @default(uuid())
  metricName  String
  metricValue Float
  recordedAt  DateTime @default(now())

  @@index([metricName, recordedAt])
}
