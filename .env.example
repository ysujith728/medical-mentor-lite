# Server Config
PORT=3001
FRONTEND_URL=http://localhost:5173

# AI Config
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase Config
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# Database Config (Prisma uses this to connect to Supabase PostgreSQL)
DATABASE_URL=postgres://postgres.[your-project-ref]:[password]@aws-0-region.pooler.supabase.com:6543/postgres
DIRECT_URL=postgres://postgres.[your-project-ref]:[password]@aws-0-region.pooler.supabase.com:5432/postgres

# Upstash Redis Config
UPSTASH_REDIS_REST_URL=https://your-upstash-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# JWT Secret (for backend auth verification, use Supabase JWT secret)
JWT_SECRET=your_supabase_jwt_secret
